// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Candidat {
  id         Int      @id @default(autoincrement())
  nom        String   @unique
  parti      String
  photoUrl   String?
  scoreMoyen Float?
  createdAt  DateTime @default(now())

  propositions Proposition[]
}

model Proposition {
  id              Int      @id @default(autoincrement())
  // Titre court généré à partir de l'analyse (resume_court/mesure_reformulee),
  // pour l'affichage sur les cartes. Nullable pour les propositions
  // antérieures à l'ajout de ce champ.
  titre           String?
  texteOriginal   String
  theme           String
  dateDeclaration DateTime
  createdAt       DateTime @default(now())

  candidatId Int
  candidat   Candidat @relation(fields: [candidatId], references: [id])

  analyses Analyse[]
}

model Analyse {
  id Int @id @default(autoincrement())

  propositionId Int
  proposition   Proposition @relation(fields: [propositionId], references: [id])

  // Score global sur 100
  scoreFaisabilite Int

  // Sous-scores du barème (poids variables selon le critère, voir
  // scripts/analyze.js — colonnes historiques, non lues par l'UI qui lit
  // directement contenuComplet.notation_detaillee ; scoreJuridique/
  // scoreOperationnel/scorePertinence portent désormais des valeurs dont le
  // nom de colonne ne correspond plus exactement au libellé du critère,
  // voir le commentaire dans saveAnalysis())
  scoreSolidite     Int
  scoreJuridique    Int
  scoreOperationnel Int
  scoreBudgetaire   Int
  scorePertinence   Int

  verdict String

  // Résumé journalistique court (~200-250 caractères) pour la carte "Prix
  // de la semaine" de la page d'accueil. Nullable pour les analyses
  // antérieures à l'ajout de ce champ.
  resumeAccueil String?

  // Texte journalistique plus développé (~400-500 caractères) pour la
  // section "Le résumé de Perlimpinpin IA" en tête de la fiche déclaration.
  // Pose la mesure et le point de tension principal, sans donner le verdict
  // ni le score. Nullable pour les analyses antérieures à ce champ.
  teaser String?

  cequiEstEtabli     String
  cequiEstProbable   String
  cequiEstDiscutable String
  cequiEstInconnu    String

  sourcesUtilisees String

  // "brouillon" | "publie"
  statut String @default("brouillon")

  versionMethodologie String @default("v1.0")

  // Réponse JSON complète renvoyée par l'API Anthropic (sortie finale, après
  // arbitrage de l'étape 3 du pipeline)
  contenuComplet Json

  // Sortie brute du contrôle qualité Mistral (étape 2 du pipeline). Nullable :
  // absent si Mistral a échoué (mode dégradé) ou pour les analyses générées
  // avant l'ajout de cette étape.
  contreAvisMistral Json?

  // Pour chaque remarque de contreAvisMistral, ce que Claude a accepté ou
  // rejeté et pourquoi (étape 3). Usage interne, jamais exposé au lecteur.
  auditArbitrage Json?

  // Détail des tokens et du coût estimé par étape du pipeline :
  // { tokensEtape1, tokensEtape2, tokensEtape3, coutEstimeTotal }
  coutPipeline Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbacks Feedback[]
}

model Feedback {
  id Int @id @default(autoincrement())

  analyseId Int
  analyse   Analyse @relation(fields: [analyseId], references: [id])

  // "like" | "dislike"
  type String

  // Raison du dislike, nullable (uniquement si type = "dislike")
  raison String?

  // Texte libre si raison = "autre"
  raisonAutre String?

  createdAt DateTime @default(now())
}

model Source {
  id  Int    @id @default(autoincrement())
  nom String
  url String

  // "institutionnelle" | "statistique" | "juridique" | "autre"
  type String

  createdAt DateTime @default(now())
}
